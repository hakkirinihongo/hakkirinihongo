---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contacts | Hakkiri Nihongo"
  description="Hakkiri Nihongo contacts. For questions, collaborations, or requests related to Japanese study, feel free to write by email."
>
  <section class="page-intro">

    <h1>Let’s get in touch</h1>

    <p class="page-lead">
      For questions, collaborations, or requests related to Hakkiri Nihongo,
      you can write to me by email. I will reply as soon as possible.
    </p>
  </section>

  <section class="contact-card">
    <h2>Email</h2>
    <p>
      <a href="mailto:contatti@hakkirinihongo.com">contatti@hakkirinihongo.com</a>
    </p>
  </section>

  <section class="contact-card">
    <h2>Facebook</h2>
    <p>
      You can also follow Hakkiri Nihongo on
      <a
        href="https://www.facebook.com/hakkirinihongo"
        target="_blank"
        rel="noopener noreferrer"
      >
        Facebook
      </a>,
      where I publish updates and new articles.
    </p>
  </section>

  <section class="contact-card">
    <h2>What you can contact me about</h2>

    <ul class="contact-list">
      <li>Questions about the site’s content</li>
      <li>Requests for clarification about articles and explanations</li>
      <li>Editorial or teaching collaborations</li>
      <li>Reports of errors or technical issues</li>
    </ul>
  </section>

  <section class="contact-note">
    <p>
      Hakkiri Nihongo is a project dedicated to the clear,
      rigorous and in-depth study of the Japanese language.
    </p>
  </section>
</BaseLayout>
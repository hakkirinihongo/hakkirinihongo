---
import BaseLayout from '../../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const articleImports = import.meta.glob('../../../content/en/**/*.mdx');

  const articles = await Promise.all(
    Object.entries(articleImports).map(async ([path, resolver]) => {
      const mod = await resolver();
      const slug = path.split('/').pop()?.replace(/\.mdx?$/, '') ?? '';

      return {
        params: { slug },
        props: {
          Content: mod.default,
          frontmatter: mod.frontmatter
        }
      };
    })
  );

  return articles;
}

const { Content, frontmatter } = Astro.props;
---

<BaseLayout
  title={frontmatter.title}
  description={frontmatter.description}
  image={frontmatter.image}
  alternateItalian={frontmatter.alternateItalian}
  alternateEnglish={Astro.url.pathname}
>
  <article class="page-article en-article-page">
    <h1>{frontmatter.title}</h1>

    {frontmatter.subtitle && (
      <p class="article-subtitle">{frontmatter.subtitle}</p>
    )}

    <Content />
  </article>

  <style>
    .en-article-page h1 {
      margin-bottom: 0.45rem;
    }

    .article-subtitle {
      margin: 0 0 2.1rem;

      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
      font-size: 0.95rem;
      line-height: 1.45;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;

      color: #1f2937;
      max-width: 780px;
    }
  </style>
</BaseLayout>
---
import BaseLayout from '../../../../layouts/BaseLayout.astro';

const normalizeJlpt = (value) => {
  return String(value ?? '')
    .toLowerCase()
    .trim()
    .replace(/[–—−]/g, '-')
    .replace(/\s*-\s*/g, '-')
    .replace(/\s+/g, '-')
    .replace(/[^\w-]/g, '');
};

const expandJlptLevels = (value) => {
  const normalized = normalizeJlpt(value);
  if (!normalized) return [];

  const allowed = new Set(['n5', 'n4', 'n3', 'n2', 'n1']);
  const parts = normalized.split('-').filter(Boolean);

  if (parts.length === 1) {
    return allowed.has(parts[0]) ? [parts[0]] : [];
  }

  if (
    parts.length === 2 &&
    allowed.has(parts[0]) &&
    allowed.has(parts[1])
  ) {
    return [normalized, ...parts];
  }

  return [];
};

const desiredOrder = ['n5', 'n4', 'n3', 'n2', 'n1'];

const sortJlptLevels = (levels) => {
  return [...levels].sort((a, b) => {
    const aParts = a.split('-');
    const bParts = b.split('-');

    if (aParts.length !== bParts.length) {
      return aParts.length - bParts.length;
    }

    const aIndex = desiredOrder.indexOf(aParts[0]);
    const bIndex = desiredOrder.indexOf(bParts[0]);

    if (aIndex !== bIndex) {
      return aIndex - bIndex;
    }

    const aSecond = aParts[1] ? desiredOrder.indexOf(aParts[1]) : -1;
    const bSecond = bParts[1] ? desiredOrder.indexOf(bParts[1]) : -1;

    return aSecond - bSecond;
  });
};

const postImports = import.meta.glob('../../../../content/en/**/*.mdx');

const posts = await Promise.all(
  Object.entries(postImports).map(async ([_, resolver]) => {
    const mod = await resolver();
    const fm = mod.frontmatter ?? {};

    return {
      jlpt: fm.jlpt ?? null
    };
  })
);

const jlptSet = new Set(
  posts.flatMap((post) => expandJlptLevels(post.jlpt)).filter(Boolean)
);

const jlptList = sortJlptLevels([...jlptSet]);
---

<BaseLayout
  title="JLPT levels | Hakkiri Nihongo"
  description="All JLPT levels covered in the English articles on Hakkiri Nihongo."
>
  <div class="page-articles">
    <nav class="breadcrumbs">
      <a href="/en/articles/">Articles</a>
      <span>›</span>
      <span>JLPT</span>
    </nav>

    <h2>JLPT levels</h2>

    <p class="archive-count">
      {jlptList.length} {jlptList.length === 1 ? 'available level' : 'available levels'}
    </p>

    <ul class="post-list">
      {jlptList.map((jlpt) => (
        <li class="post-item">
          <h3 class="post-title">
            <a class="post-link" href={`/en/articles/jlpt/${normalizeJlpt(jlpt)}/`}>
              JLPT {jlpt.toUpperCase()}
            </a>
          </h3>
        </li>
      ))}
    </ul>
  </div>
</BaseLayout>
---
import BaseLayout from '../../../../layouts/BaseLayout.astro';

const normalizeJlpt = (value) => {
  return String(value ?? '')
    .toLowerCase()
    .trim()
    .replace(/[–—−]/g, '-')
    .replace(/\s*-\s*/g, '-')
    .replace(/\s+/g, '-')
    .replace(/[^\w-]/g, '');
};

const expandJlptLevels = (value) => {
  const normalized = normalizeJlpt(value);
  if (!normalized) return [];

  const allowed = new Set(['n5', 'n4', 'n3', 'n2', 'n1']);
  const parts = normalized.split('-').filter(Boolean);

  if (parts.length === 1) {
    return allowed.has(parts[0]) ? [parts[0]] : [];
  }

  if (parts.length === 2 && allowed.has(parts[0]) && allowed.has(parts[1])) {
    return [normalized, ...parts];
  }

  return [];
};

export async function getStaticPaths() {
  const postImports = import.meta.glob('../../../../content/en/**/*.mdx');
  const allowed = new Set(['n5', 'n4', 'n3', 'n2', 'n1']);

  const allLevels = await Promise.all(
    Object.entries(postImports).map(async ([_, resolver]) => {
      const mod = await resolver();
      const rawJlpt = String(mod.frontmatter?.jlpt ?? '')
        .toLowerCase()
        .trim()
        .replace(/[–—−]/g, '-')
        .replace(/\s*-\s*/g, '-')
        .replace(/\s+/g, '-')
        .replace(/[^\w-]/g, '');

      if (!rawJlpt) return [];

      const parts = rawJlpt.split('-').filter(Boolean);

      if (parts.length === 1) {
        return allowed.has(parts[0]) ? [parts[0]] : [];
      }

      if (
        parts.length === 2 &&
        allowed.has(parts[0]) &&
        allowed.has(parts[1])
      ) {
        return [rawJlpt, ...parts];
      }

      return [];
    })
  );

  const uniqueLevels = [...new Set(allLevels.flat().filter(Boolean))];

  return uniqueLevels.map((level) => ({
    params: { level },
  }));
}

const postImports = import.meta.glob('../../../../content/en/**/*.mdx');

const posts = await Promise.all(
  Object.entries(postImports).map(async ([path, resolver]) => {
    const mod = await resolver();
    const fm = mod.frontmatter ?? {};
    const slug = fm.slug ?? path.split('/').pop().replace(/\.mdx?$/, '');

    return { slug, frontmatter: fm };
  })
);

posts.sort((a, b) => {
  const dateA = a.frontmatter.date ? new Date(a.frontmatter.date) : new Date(0);
  const dateB = b.frontmatter.date ? new Date(b.frontmatter.date) : new Date(0);
  return dateB.getTime() - dateA.getTime();
});

const level = Astro.params.level;

const filteredPosts = posts.filter(({ frontmatter }) => {
  return expandJlptLevels(frontmatter.jlpt).includes(level);
});

const jlptCount = filteredPosts.length;
---

<BaseLayout
  title={`JLPT ${String(level).toUpperCase()} | Japanese Grammar Articles – Hakkiri Nihongo`}
  description={`Japanese grammar articles for JLPT ${String(level).toUpperCase()}: explanations, grammar analysis, and in-depth study.`}
>
  <div class="page-articles">
    <nav class="breadcrumbs">
      <a href="/en/articles/">Articles</a>
      <span>›</span>
      <a href="/en/articles/jlpt/">JLPT</a>
      <span>›</span>
      <span>{String(level).toUpperCase()}</span>
    </nav>

    <h2>JLPT {String(level).toUpperCase()}</h2>

    <p class="jlpt-intro">
      Japanese grammar articles suitable for JLPT {String(level).toUpperCase()}.
      In this section you’ll find grammar explanations, distinctions, and detailed breakdowns
      useful for learners studying Japanese at this level.
    </p>

    <p class="archive-count">
      {jlptCount} {jlptCount === 1 ? 'article at this level' : 'articles at this level'}
    </p>

    <ul class="post-list">
      {filteredPosts.map(({ slug, frontmatter }) => (
        <li class="post-item">
          <a class="post-thumb" href={`/en/articles/${slug}/`} aria-hidden="true" tabindex="-1">
            <img src={frontmatter.image ?? '/og-image.png'} alt="" loading="lazy" />
          </a>

          <div class="post-content">
            <h3 class="post-title">
              <a class="post-link" href={`/en/articles/${slug}/`}>
                {frontmatter.title ?? slug}
              </a>
            </h3>

            {frontmatter.description && (
              <p class="post-description">
                <a class="post-link" href={`/en/articles/${slug}/`}>
                  {frontmatter.description}
                </a>
              </p>
            )}

            <div class="post-meta">
              {frontmatter.date && (
                <time datetime={frontmatter.date}>
                  {new Date(frontmatter.date).toLocaleDateString('en-US')}
                </time>
              )}

              {frontmatter.jlpt && (
                <a class="tag" href={`/en/articles/jlpt/${normalizeJlpt(frontmatter.jlpt)}/`}>
                  JLPT {frontmatter.jlpt}
                </a>
              )}
            </div>
          </div>
        </li>
      ))}

      {filteredPosts.length === 0 && (
        <li class="post-item">
          There are no articles for this JLPT level at the moment.
        </li>
      )}
    </ul>
  </div>
</BaseLayout>
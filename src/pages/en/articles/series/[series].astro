---
import BaseLayout from '../../../../layouts/BaseLayout.astro';

const normalizeSeries = (value) => {
  return String(value ?? '')
    .toLowerCase()
    .trim()
    .replace(/[–—−]/g, '-')
    .replace(/\s+/g, '-')
    .replace(/[^\w-]/g, '');
};

export async function getStaticPaths() {
  const postImports = import.meta.glob('../../../../content/en/**/*.mdx');

  const allSeries = await Promise.all(
    Object.entries(postImports).map(async ([_, resolver]) => {
      const mod = await resolver();

      return String(mod.frontmatter?.series ?? '')
        .toLowerCase()
        .trim()
        .replace(/[–—−]/g, '-')
        .replace(/\s+/g, '-')
        .replace(/[^\w-]/g, '');
    })
  );

  const uniqueSeries = [...new Set(allSeries.filter(Boolean))];

  return uniqueSeries.map((series) => ({
    params: { series }
  }));
}
const postImports = import.meta.glob('../../../../content/en/**/*.mdx');

const posts = await Promise.all(
  Object.entries(postImports).map(async ([path, resolver]) => {
    const mod = await resolver();
    const fm = mod.frontmatter ?? {};
    const slug = fm.slug ?? path.split('/').pop().replace(/\.mdx?$/, '');

    return {
      slug,
      frontmatter: fm
    };
  })
);

posts.sort((a, b) => {
  const dateA = a.frontmatter.date ? new Date(a.frontmatter.date) : new Date(0);
  const dateB = b.frontmatter.date ? new Date(b.frontmatter.date) : new Date(0);
  return dateB.getTime() - dateA.getTime();
});

const series = Astro.params.series;

const filteredPosts = posts.filter(({ frontmatter }) => {
  return normalizeSeries(frontmatter.series).includes(series);
});

const seriesCount = filteredPosts.length;
const seriesTitle =
  filteredPosts[0]?.frontmatter?.series ?? String(series);
const normalizeJlpt = (value) => {
  return String(value ?? '')
    .toLowerCase()
    .trim()
    .replace(/[–—−]/g, '-')
    .replace(/\s*-\s*/g, '-')
    .replace(/\s+/g, '-')
    .replace(/[^\w-]/g, '');
};

const jlptSummary = Object.values(
  filteredPosts.reduce((acc, { frontmatter }) => {
    const jlpt = frontmatter.jlpt;
    if (!jlpt) return acc;

    const key = String(jlpt).trim();

    if (!acc[key]) {
      acc[key] = {
        label: key,
        slug: normalizeJlpt(key),
        count: 0
      };
    }

    acc[key].count += 1;
    return acc;
  }, {})
);
---

<BaseLayout
  title={`${seriesTitle} | Hakkiri Nihongo`}
  description={`Articles in the "${seriesTitle}" editorial series on Hakkiri Nihongo.`}
>
  <div class="page-articles">
    <nav class="breadcrumbs">
      <a href="/en/articles/">Articles</a>
      <span>›</span>
      <a href="/en/articles/series/">Series</a>
      <span>›</span>
      <span>{seriesTitle}</span>
    </nav>

    <h2>{seriesTitle}</h2>

    <p class="archive-count">
      {seriesCount} {seriesCount === 1 ? 'article in this series' : 'articles in this series'}
    </p>
{jlptSummary.length > 0 && (
  <div class="archive-filter-summary">
    <span>JLPT levels in this series:</span>

    {jlptSummary.map((item) => (
      <a class="tag" href={`/en/articles/jlpt/${item.slug}/`}>
        JLPT {item.label} ({item.count})
      </a>
    ))}
  </div>
)}

    <ul class="post-list">
      {filteredPosts.map(({ slug, frontmatter }) => (
        <li class="post-item">
          <a
            class="post-thumb"
            href={`/en/articles/${slug}/`}
            aria-hidden="true"
            tabindex="-1"
          >
            <img
              src={frontmatter.image ?? '/og-image.png'}
              alt=""
              loading="lazy"
            />
          </a>

          <div class="post-content">
            <h3 class="post-title">
              <a class="post-link" href={`/en/articles/${slug}/`}>
                {frontmatter.title ?? slug}
              </a>
            </h3>

            {frontmatter.description && (
              <p class="post-description">
                <a class="post-link" href={`/en/articles/${slug}/`}>
                  {frontmatter.description}
                </a>
              </p>
            )}

            <div class="post-meta">
              {frontmatter.date && (
                <time datetime={frontmatter.date}>
                  {new Date(frontmatter.date).toLocaleDateString('en-US')}
                </time>
              )}

              {frontmatter.series && (
                <a
                  class="tag"
                  href={`/en/articles/series/${normalizeSeries(frontmatter.series)}/`}
                >
                  {frontmatter.series}
                </a>
              )}
{frontmatter.jlpt && (
  <span class="tag">JLPT {frontmatter.jlpt}</span>
)}
            </div>
          </div>
        </li>
      ))}

      {filteredPosts.length === 0 && (
        <li class="post-item">
          There are no articles in this series at the moment.
        </li>
      )}
    </ul>
  </div>
</BaseLayout>
---
import BaseLayout from '../../../layouts/BaseLayout.astro';

const postImports = import.meta.glob('../../../content/en/**/*.mdx');

const posts = await Promise.all(
  Object.entries(postImports).map(async ([path, resolver]) => {
    const mod = await resolver();
    const fm = mod.frontmatter ?? {};
    const slug = fm.slug ?? path.split('/').pop().replace(/\.mdx?$/, '');

    return {
      slug,
      frontmatter: fm,
    };
  })
);

posts.sort((a, b) => {
  const dateA = a.frontmatter.date ? new Date(a.frontmatter.date) : new Date(0);
  const dateB = b.frontmatter.date ? new Date(b.frontmatter.date) : new Date(0);
  return dateB.getTime() - dateA.getTime();
});

const categoriesMap = {
  'concepts-and-distinctions': 'Concepts & Distinctions',
  'grammar-dissections': 'Grammar Dissections',
  'niche-japanese': 'Niche Japanese',
  'history-of-grammar': 'History of Grammar'
};

const normalizeSeries = (value) => {
  return String(value ?? '')
    .toLowerCase()
    .trim()
    .replace(/[–—−]/g, '-')
    .replace(/\s+/g, '-')
    .replace(/[^\w-]/g, '');
};

const normalizeJlpt = (value) => {
  return String(value ?? '')
    .toLowerCase()
    .trim()
    .replace(/[–—−]/g, '-')
    .replace(/\s*-\s*/g, '-')
    .replace(/\s+/g, '-')
    .replace(/[^\w-]/g, '');
};

const filteredPosts = posts;
---

<BaseLayout
  title="Articles – advanced Japanese grammar | Hakkiri Nihongo"
  description="Japanese grammar articles in English: distinctions, nuance, niche grammar and advanced explanations made clear."
  alternateItalian="/articoli/"
  alternateEnglish="/en/articles/"
>
  <div class="page-articles page-articles-bg">
    <h2>Articles</h2>

    <nav class="category-nav">
      <a href="/en/articles/" class="active">All</a>

      {Object.entries(categoriesMap).map(([slug, title]) => (
        <a href={`/en/articles/c/${slug}/`}>{title}</a>
      ))}
    </nav>

    <p class="archive-links">
      <a href="/en/articles/series/">Browse all series</a>
      <span> · </span>
      <a href="/en/articles/jlpt/">Browse all JLPT levels</a>
    </p>

    <ul class="post-list">
      {filteredPosts.map(({ slug, frontmatter }) => (
        <li class="post-item">
          <a
            class="post-thumb"
            href={`/en/articles/${slug}/`}
            aria-hidden="true"
            tabindex="-1"
          >
            <img
              src={frontmatter.image ?? '/og-image.png'}
              alt=""
              loading="lazy"
            />
          </a>

          <div class="post-content">
            <h3 class="post-title">
              <a class="post-link" href={`/en/articles/${slug}/`}>
                {frontmatter.title ?? slug}
              </a>
            </h3>

            {frontmatter.description && (
              <p class="post-description">
                <a class="post-link" href={`/en/articles/${slug}/`}>
                  {frontmatter.description}
                </a>
              </p>
            )}

            <div class="post-meta">
              {frontmatter.date && (
                <time datetime={frontmatter.date}>
                  {new Date(frontmatter.date).toLocaleDateString('en-US')}
                </time>
              )}

              {frontmatter.series && (
                <a
                  class="series"
                  href={`/en/articles/series/${normalizeSeries(frontmatter.series)}/`}
                >
                  {frontmatter.series}
                </a>
              )}

              {frontmatter.jlpt && (
                <span class="tag">JLPT {frontmatter.jlpt}</span>
              )}
            </div>
          </div>
        </li>
      ))}

      {filteredPosts.length === 0 && (
        <li class="post-item">
          No English articles available yet.
        </li>
      )}
    </ul>
  </div>
</BaseLayout>
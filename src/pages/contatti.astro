---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contatti | Hakkiri Nihongo"
  description="Contatti di Hakkiri Nihongo. Per domande, collaborazioni o richieste relative allo studio del giapponese, scrivi via email."
>
  <section class="page-intro">
    
    <h1>Mettiamoci in contatto</h1>
    <p class="page-lead">
      Per domande, collaborazioni o richieste legate a Hakkiri Nihongo,
      puoi scrivermi via email. Ti risponderò appena possibile.
    </p>
  </section>

  <section class="contact-card">
    <h2>Email</h2>
    <p>
     <a href="mailto:contatti@hakkirinihongo.com">contatti@hakkirinihongo.com</a>
    </p>
  </section>

  <!-- NUOVA SEZIONE FACEBOOK -->
  <section class="contact-card">
    <h2>Facebook</h2>
    <p>
      Puoi seguire Hakkiri Nihongo anche su
      <a href="https://www.facebook.com/hakkirinihongo" target="_blank" rel="noopener noreferrer">
        Facebook
      </a>,
      dove pubblico aggiornamenti e nuovi articoli.
    </p>
  </section>

  <section class="contact-card">
    <h2>Per cosa puoi contattarmi</h2>
    <ul class="contact-list">
      <li>Domande sui contenuti del sito</li>
      <li>Richieste di chiarimento su articoli e spiegazioni</li>
      <li>Collaborazioni editoriali o didattiche</li>
      <li>Segnalazioni di errori o problemi tecnici</li>
    </ul>
  </section>

  <section class="contact-note">
    <p>
      Hakkiri Nihongo è un progetto dedicato allo studio chiaro, rigoroso e approfondito
      della lingua giapponese.
    </p>
  </section>
</BaseLayout>

---
import BaseLayout from '../../layouts/BaseLayout.astro';

const postImports = import.meta.glob('../../content/articoli/**/*.mdx');

const posts = await Promise.all(
  Object.entries(postImports).map(async ([path, resolver]) => {
    const mod = await resolver();
    const fm = mod.frontmatter ?? {};
    const slug = fm.slug ?? path.split('/').pop().replace(/\.mdx?$/, '');

    return {
      slug,
      frontmatter: fm,
    };
  })
);

posts.sort((a, b) => {
  const dateA = a.frontmatter.date ? new Date(a.frontmatter.date) : new Date(0);
  const dateB = b.frontmatter.date ? new Date(b.frontmatter.date) : new Date(0);
  return dateB.getTime() - dateA.getTime();
});

const categoriesMap = {
  'concetti-e-distinzioni': 'Concetti e Distinzioni',
  'dissezionamenti-grammaticali': 'Dissezionamenti grammaticali',
  'giapponese-di-nicchia': 'Giapponese di nicchia',
  'storia-della-grammatica': 'Storia della grammatica'
};

const normalizeSeries = (value) => {
  return String(value ?? '')
    .toLowerCase()
    .trim()
    .replace(/[–—−]/g, '-')
    .replace(/\s+/g, '-')
    .replace(/[^\w-]/g, '');
};

const normalizeJlpt = (value) => {
  return String(value ?? '')
    .toLowerCase()
    .trim()
    .replace(/[–—−]/g, '-')
    .replace(/\s*-\s*/g, '-')
    .replace(/\s+/g, '-')
    .replace(/[^\w-]/g, '');
};

const isFilterableJlpt = (value) => {
  const raw = String(value ?? '').trim().toLowerCase();

  if (raw === 'tutti i livelli' || raw === 'tutti-i-livelli') {
    return true;
  }

  const normalized = normalizeJlpt(value);
  const parts = normalized.split('-').filter(Boolean);
  const allowed = new Set(['n5', 'n4', 'n3', 'n2', 'n1']);

  if (parts.length === 1) {
    return allowed.has(parts[0]);
  }

  if (parts.length === 2) {
    return allowed.has(parts[0]) && allowed.has(parts[1]);
  }

  return false;
};

const catFromQuery = Astro.url.searchParams.get('cat');
if (catFromQuery) {
  return Astro.redirect(`/articoli/c/${catFromQuery}/`, 301);
}

const filteredPosts = posts;
---

<BaseLayout
  title="Articoli – grammatica giapponese avanzata | Hakkiri Nihongo"
  description="Articoli di grammatica giapponese avanzata: concetti, distinzioni, grammatica di nicchia e approfondimenti per studenti di livello intermedio e avanzato."
>
  <div class="page-articles">
    <h2>Articoli</h2>

    <nav class="category-nav">
      <script>
        const params = new URLSearchParams(window.location.search);
        const cat = params.get("cat");
        if (cat) {
          window.location.replace(`/articoli/c/${cat}/`);
        }
      </script>

      <a href="/articoli/" class="active">Tutti</a>
      {Object.entries(categoriesMap).map(([slug, title]) => (
        <a href={`/articoli/c/${slug}/`}>{title}</a>
      ))}
    </nav>

    <p class="archive-links">
      <a href="/articoli/serie/">Vedi tutte le serie</a>
      <span> · </span>
      <a href="/articoli/jlpt/">Vedi tutti i livelli JLPT</a>
    </p>

    <ul class="post-list">
      {filteredPosts.map(({ slug, frontmatter }) => (
        <li class="post-item">
          <h3 class="post-title">
            <a class="post-link" href={`/articoli/${slug}/`}>
              {frontmatter.title ?? slug}
            </a>
          </h3>

          {frontmatter.description && (
            <p class="post-description">
              <a class="post-link" href={`/articoli/${slug}/`}>
                {frontmatter.description}
              </a>
            </p>
          )}

          <div class="post-meta">
            {frontmatter.date && (
              <time datetime={frontmatter.date}>
                {new Date(frontmatter.date).toLocaleDateString('it-IT')}
              </time>
            )}

            {frontmatter.series && (
              <a
                class="series"
                href={`/articoli/serie/${normalizeSeries(frontmatter.series)}/`}
              >
                {frontmatter.series}
              </a>
            )}

            {frontmatter.jlpt && (
              isFilterableJlpt(frontmatter.jlpt) ? (
                <a
                  class="tag"
                  href={
                    normalizeJlpt(frontmatter.jlpt) === 'tutti-i-livelli'
                      ? '/articoli/jlpt/'
                      : `/articoli/jlpt/${normalizeJlpt(frontmatter.jlpt)}/`
                  }
                >
                  JLPT {frontmatter.jlpt}
                </a>
              ) : (
                <span class="tag">JLPT {frontmatter.jlpt}</span>
              )
            )}

            {frontmatter.tags && frontmatter.tags.map((tag) => (
              <span class="tag">{tag}</span>
            ))}
          </div>
        </li>
      ))}

      {filteredPosts.length === 0 && (
        <li class="post-item">Non ci sono articoli in questa sezione al momento.</li>
      )}
    </ul>
  </div>
</BaseLayout>
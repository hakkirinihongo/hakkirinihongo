---
import BaseLayout from '../../layouts/BaseLayout.astro';

// 1) OBBLIGATORIO: generiamo gli slug
export async function getStaticPaths() {
  const postModules = import.meta.glob('../../content/articoli/**/*.mdx', { eager: true });

  const posts = Object.entries(postModules).map(([path, mod]) => {
    const frontmatter = mod.frontmatter ?? {};
    const fallbackSlug = path.split('/').pop().replace('.mdx', '');
    const slug = frontmatter.slug ?? fallbackSlug;

    return { slug };
  });

  return posts.map((post) => ({
    params: { slug: post.slug },
  }));
}

// 2) Carichiamo articoli e vocab
const postModules = import.meta.glob('../../content/articoli/**/*.mdx', { eager: true });
const vocabModules = import.meta.glob('../../data/vocab/*.vocab.json', { eager: true });

const posts = Object.entries(postModules).map(([path, mod]) => {
  const frontmatter = mod.frontmatter ?? {};
  const fallbackSlug = path.split('/').pop().replace('.mdx', '');
  const slug = frontmatter.slug ?? fallbackSlug;

  const vocabPath = `../../data/vocab/${fallbackSlug}.vocab.json`;
  const vocabModule = vocabModules[vocabPath];
  const vocab = vocabModule?.default ?? [];

  return { slug, mod, frontmatter, vocab };
});

const { slug } = Astro.params;
const post = posts.find((p) => p.slug === slug);

if (!post) {
  throw new Error(`Articolo non trovato: ${slug}`);
}

const Content = post.mod.default;
const title = post.frontmatter.title ?? slug;

const headings = await post.mod.getHeadings?.() ?? [];
const articleToc = headings.filter((heading) => heading.depth === 2);

const category = post.frontmatter.category;
const series = post.frontmatter.series;

const categoryLabels = {
  "concetti-e-distinzioni": "Concetti e Distinzioni",
  "dissezionamenti-grammaticali": "Dissezioni grammaticali",
  "giapponese-di-nicchia": "Giapponese di nicchia",
  "storia-della-grammatica": "Storia della grammatica",
};

const categoryTitle = categoryLabels[category] ?? category;

const relatedPosts = posts
  .filter((p) => p.slug !== slug)
  .map((p) => {
    let score = 0;

    if (series && p.frontmatter.series === series) score += 3;
    if (category && p.frontmatter.category === category) score += 2;
    if (post.frontmatter.jlpt && p.frontmatter.jlpt === post.frontmatter.jlpt) score += 1;

    return {
      ...p,
      score,
      date: p.frontmatter.date ?? '',
      title: p.frontmatter.title ?? p.slug,
      description: p.frontmatter.description ?? '',
    };
  })
  .sort((a, b) => {
    if (b.score !== a.score) return b.score - a.score;
    return String(b.date).localeCompare(String(a.date));
  })
  .slice(0, 3);
---

<BaseLayout
  title={`${title} | Hakkiri Nihongo`}
  description={post.frontmatter.description}
  image={post.frontmatter.image}
>
  <div class="article-layout">
    <article class="page-article prose prose-lg max-w-none">
      <h1 class="post-title">
        {title}
        {post.frontmatter.subtitle && (
          <span class="post-subtitle">
            {post.frontmatter.subtitle}
          </span>
        )}
      </h1>

      {category && (
        <p class="post-category">
          Categoria: <a href={`/articoli/c/${category}/`}>{categoryTitle}</a>
        </p>
      )}

      <Content />

      {false && post.vocab.length > 0 && (
        <section class="article-vocab" aria-labelledby="article-vocab-title">
          <h2 id="article-vocab-title">Vocabolario dell’articolo</h2>

          <p class="article-vocab-intro">
            Una selezione di vocaboli giapponesi presenti nell’articolo, estratti automaticamente e utili per ripassare lessico, forme grammaticali e termini ricorrenti.
          </p>

          <ul class="article-vocab-list">
            {post.vocab.slice(0, 40).map((item) => (
              <li>
                <span lang="ja">{item.term}</span>
              </li>
            ))}
          </ul>
        </section>
      )}
    </article>

    {articleToc.length > 0 && (
      <aside class="article-sidebar">
        <nav class="article-toc" aria-labelledby="article-toc-title">
          <p id="article-toc-title" class="article-toc-title">
            In questo articolo
          </p>

          <ol class="article-toc-list">
            {articleToc.map((heading) => (
              <li>
                <a href={`#${heading.slug}`}>{heading.text}</a>
              </li>
            ))}
          </ol>
        </nav>
      </aside>
    )}
  </div>

  {relatedPosts.length > 0 && (
    <section class="related-posts" aria-labelledby="related-posts-title">
      <h2 id="related-posts-title" class="related-posts-title">Vedi anche</h2>

      <div class="related-posts-grid">
        {relatedPosts.map((related) => {
          const relatedCategory = related.frontmatter.category;
          const relatedCategoryTitle = categoryLabels[relatedCategory] ?? relatedCategory;

          return (
            <a class="related-post-card" href={`/articoli/${related.slug}/`}>
              <span class="related-post-card-image">
                <img
                  src={related.frontmatter.image ?? '/og-image.png'}
                  alt=""
                  loading="lazy"
                />
              </span>

              <span class="related-post-card-body">
                {relatedCategory && (
                  <span class="related-post-card-category">{relatedCategoryTitle}</span>
                )}

                <h3>{related.title}</h3>

                {related.description && <p>{related.description}</p>}

                <span class="related-post-card-link">Leggi l’articolo →</span>
              </span>
            </a>
          );
        })}
      </div>
    </section>
  )}

  <script>
    const updateActiveTocLink = () => {
      const headings = Array.from(document.querySelectorAll('h2[id]'));
      const tocLinks = Array.from(document.querySelectorAll('.article-toc a'));

      let currentHeadingId = null;

      headings.forEach((heading) => {
        const rect = heading.getBoundingClientRect();

        if (rect.top <= 500) {
          currentHeadingId = heading.id;
        }
      });

      tocLinks.forEach((link) => {
        link.classList.remove('is-active');

        if (link.getAttribute('href') === `#${currentHeadingId}`) {
          link.classList.add('is-active');
        }
      });
    };

    document.addEventListener('scroll', updateActiveTocLink, { passive: true });
    window.addEventListener('load', updateActiveTocLink);

    updateActiveTocLink();

    const tocLinks = document.querySelectorAll('.article-toc a');

    tocLinks.forEach((link) => {
      link.addEventListener('click', (event) => {
        event.preventDefault();

        const targetId = link.getAttribute('href');
        const target = document.querySelector(targetId);

        if (!target) return;

        const offset = 120;

        const targetPosition =
          target.getBoundingClientRect().top +
          window.scrollY -
          offset;

        const startPosition = window.scrollY;
        const distance = targetPosition - startPosition;
        const duration = Math.min(1800, Math.max(900, Math.abs(distance) * 0.7));

        let startTime = null;

        const easeOutCubic = (t) => 1 - Math.pow(1 - t, 3);

        const animateScroll = (currentTime) => {
          if (startTime === null) {
            startTime = currentTime;
          }

          const elapsed = currentTime - startTime;
          const progress = Math.min(elapsed / duration, 1);
          const easedProgress = easeOutCubic(progress);

          window.scrollTo(
            0,
            startPosition + distance * easedProgress
          );

          if (progress < 1) {
            requestAnimationFrame(animateScroll);
          }
        };

        requestAnimationFrame(animateScroll);
      });
    });
  </script>
</BaseLayout>
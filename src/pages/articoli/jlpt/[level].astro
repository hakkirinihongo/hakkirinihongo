---
import BaseLayout from '../../../layouts/BaseLayout.astro';

const normalizeJlpt = (value) => {
  return String(value ?? '')
    .toLowerCase()
    .trim()
    .replace(/[–—−]/g, '-')
    .replace(/\s*-\s*/g, '-')
    .replace(/\s+/g, '-')
    .replace(/[^\w-]/g, '');
};

const isAllLevelsJlpt = (value) => {
  const raw = String(value ?? '').trim().toLowerCase();
  return raw === 'tutti i livelli' || raw === 'tutti-i-livelli';
};

const isFilterableJlpt = (value) => {
  if (isAllLevelsJlpt(value)) return true;

  const normalized = normalizeJlpt(value);
  const parts = normalized.split('-').filter(Boolean);
  const allowed = new Set(['n5', 'n4', 'n3', 'n2', 'n1']);

  if (parts.length === 1) return allowed.has(parts[0]);
  if (parts.length === 2) return allowed.has(parts[0]) && allowed.has(parts[1]);

  return false;
};

const expandJlptLevels = (value) => {
  if (isAllLevelsJlpt(value)) {
    return ['n5', 'n4', 'n3', 'n2', 'n1'];
  }

  const normalized = normalizeJlpt(value);
  if (!normalized) return [];

  const parts = normalized.split('-').filter(Boolean);

  if (parts.length <= 1) return [normalized];

  return [...new Set([normalized, ...parts])];
};

const normalizeSeries = (value) => {
  return String(value ?? '')
    .toLowerCase()
    .trim()
    .replace(/[–—−]/g, '-')
    .replace(/\s+/g, '-')
    .replace(/[^\w-]/g, '');
};

export async function getStaticPaths() {
  const postImports = import.meta.glob('../../../content/articoli/**/*.mdx');

  const allLevels = await Promise.all(
    Object.entries(postImports).map(async ([_, resolver]) => {
      const mod = await resolver();
      const fm = mod.frontmatter ?? {};

      if (!fm.jlpt) return [];

      const raw = String(fm.jlpt ?? '').trim().toLowerCase();

      // "Tutti i livelli" compare nei livelli singoli, ma non genera una pagina propria
      if (raw === 'tutti i livelli' || raw === 'tutti-i-livelli') {
        return ['n5', 'n4', 'n3', 'n2', 'n1'];
      }

      const normalized = String(fm.jlpt ?? '')
        .toLowerCase()
        .trim()
        .replace(/[–—−]/g, '-')
        .replace(/\s*-\s*/g, '-')
        .replace(/\s+/g, '-')
        .replace(/[^\w-]/g, '');

      const parts = normalized.split('-').filter(Boolean);
      const allowed = new Set(['n5', 'n4', 'n3', 'n2', 'n1']);

      let isValid = false;

      if (parts.length === 1) {
        isValid = allowed.has(parts[0]);
      } else if (parts.length === 2) {
        isValid = allowed.has(parts[0]) && allowed.has(parts[1]);
      }

      if (!isValid) return [];

      if (parts.length <= 1) return [normalized];

      return [...new Set([normalized, ...parts])];
    })
  );

  const uniqueLevels = [...new Set(allLevels.flat().filter(Boolean))];

  return uniqueLevels.map((level) => ({
    params: { level }
  }));
}

const postImports = import.meta.glob('../../../content/articoli/**/*.mdx');

const posts = await Promise.all(
  Object.entries(postImports).map(async ([path, resolver]) => {
    const mod = await resolver();
    const fm = mod.frontmatter ?? {};
    const slug = fm.slug ?? path.split('/').pop().replace(/\.mdx?$/, '');

    return {
      slug,
      frontmatter: fm,
    };
  })
);

posts.sort((a, b) => {
  const dateA = a.frontmatter.date ? new Date(a.frontmatter.date) : new Date(0);
  const dateB = b.frontmatter.date ? new Date(b.frontmatter.date) : new Date(0);
  return dateB.getTime() - dateA.getTime();
});

const level = Astro.params.level;

const filteredPosts = posts.filter(({ frontmatter }) => {
  if (!frontmatter.jlpt || !isFilterableJlpt(frontmatter.jlpt)) return false;
  return expandJlptLevels(frontmatter.jlpt).includes(level);
});

const jlptCount = filteredPosts.length;

const jlptPageJsonLd = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": `JLPT ${String(level).toUpperCase()}`,
  "url": Astro.url.href,
  "isPartOf": {
    "@type": "WebSite",
    "name": "Hakkiri Nihongo",
    "url": "https://hakkirinihongo.com"
  }
};

const visibleSeries = Object.entries(
  filteredPosts.reduce((acc, { frontmatter }) => {
    if (!frontmatter.series) return acc;
    acc[frontmatter.series] = (acc[frontmatter.series] ?? 0) + 1;
    return acc;
  }, {})
);
---

<BaseLayout
  title={`JLPT ${String(level).toUpperCase()} | Articoli di grammatica giapponese – Hakkiri Nihongo`}
  description={`Articoli di grammatica giapponese per il livello JLPT ${String(level).toUpperCase()}: spiegazioni, analisi grammaticali e approfondimenti.`}
>
  <script type="application/ld+json" set:html={JSON.stringify(jlptPageJsonLd)} />

  <div class="page-articles">
    <nav class="breadcrumbs">
      <a href="/articoli">Articoli</a>
      <span>›</span>
      <span>JLPT</span>
      <span>›</span>
      <span>{String(level).toUpperCase()}</span>
    </nav>

    <h2>JLPT {String(level).toUpperCase()}</h2>

    <p class="jlpt-intro">
      Articoli di grammatica giapponese adatti al JLPT {String(level).toUpperCase()}.
      In questa sezione trovi spiegazioni grammaticali, distinzioni e dissezionamenti utili
      per chi sta studiando la lingua giapponese a questo livello.
    </p>

    <p class="archive-count">
      {jlptCount} {jlptCount === 1 ? 'articolo in questo livello' : 'articoli in questo livello'}
    </p>

    {visibleSeries.length > 0 && (
      <div class="taxonomy-links">
        <p class="taxonomy-label">
          Serie di articoli presenti nel livello JLPT {String(level).toUpperCase()}:
        </p>
        {visibleSeries.map(([seriesName, count]) => (
          <a class="series" href={`/articoli/serie/${normalizeSeries(seriesName)}`}>
            {seriesName} ({count})
          </a>
        ))}
      </div>
    )}

    <ul class="post-list">
      {filteredPosts.map(({ slug, frontmatter }) => (
        <li class="post-item">
          <h3 class="post-title">
            <a class="post-link" href={`/articoli/${slug}`}>
              {frontmatter.title ?? slug}
            </a>
          </h3>

          {frontmatter.description && (
            <p class="post-description">
              <a class="post-link" href={`/articoli/${slug}`}>
                {frontmatter.description}
              </a>
            </p>
          )}

          <div class="post-meta">
            {frontmatter.date && (
              <time datetime={frontmatter.date}>
                {new Date(frontmatter.date).toLocaleDateString('it-IT')}
              </time>
            )}

            {frontmatter.series && (
              <a
                class="series"
                href={`/articoli/serie/${normalizeSeries(frontmatter.series)}`}
              >
                {frontmatter.series}
              </a>
            )}

            {frontmatter.jlpt && (
              isFilterableJlpt(frontmatter.jlpt) ? (
                <a
                  class="tag"
                  href={
                    isAllLevelsJlpt(frontmatter.jlpt)
                      ? '/articoli/jlpt'
                      : `/articoli/jlpt/${normalizeJlpt(frontmatter.jlpt)}`
                  }
                >
                  JLPT {frontmatter.jlpt}
                </a>
              ) : (
                <span class="tag">JLPT {frontmatter.jlpt}</span>
              )
            )}
          </div>
        </li>
      ))}

      {filteredPosts.length === 0 && (
        <li class="post-item">
          Non ci sono articoli per questo livello JLPT al momento.
        </li>
      )}
    </ul>
  </div>
</BaseLayout>
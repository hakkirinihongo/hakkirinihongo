---
import BaseLayout from '../layouts/BaseLayout.astro';

// Define the categories displayed on the home page.
const categories = [
  {
    slug: 'concetti-e-distinzioni',
    title: 'Concetti e Distinzioni',
    description: 'Distinguere significa capire.'
  },
  {
    slug: 'dissezionamenti-grammaticali',
    title: 'Dissezionamenti grammaticali',
    description: 'La grammatica non è una regola.'
  },
  {
    slug: 'giapponese-di-nicchia',
    title: 'Giapponese di nicchia',
    description: 'Quello che di solito non viene spiegato.'
  },
  {
    slug: 'storia-della-grammatica',
    title: 'Storia della grammatica',
    description: 'Tornare alle origini per capire.'
  }
];

// Recuperiamo automaticamente tutti gli articoli
const postModules = import.meta.glob('../content/articoli/**/*.mdx', { eager: true });

const posts = Object.entries(postModules).map(([path, mod]) => {
  const frontmatter = mod.frontmatter ?? {};
  const fallbackSlug = path.split('/').pop().replace('.mdx', '');
  const slug = frontmatter.slug ?? fallbackSlug;

  return {
    slug,
    title: frontmatter.title ?? slug,
    date: frontmatter.date ?? '',
  };
});

// Ordiniamo per data
posts.sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());

// Prendiamo gli ultimi 5
const latestPosts = posts.slice(0, 5);
---

<BaseLayout title="Hakkiri Nihongo | grammatica giapponese avanzata spiegata chiaramente">

  <section class="hero">
  <div class="hero-inner">
    <h1>Hakkiri Nihongo</h1>

    <h2>Capire il giapponese oltre le regole</h2>

    <p>
      Benvenuti in Hakkiri Nihongo, il vostro punto di riferimento per lo studio della grammatica giapponese di livello avanzato.
      Sfoglia le nostre sezioni per scoprire concetti, distinzioni e approfondimenti grammaticali.
    </p>
  </div>
</section>

  <section class="categories">
    {categories.map((cat) => (
      <a href={`/articoli/c/${cat.slug}/`} class="category-card" id={cat.slug}>
        <h3>{cat.title}</h3>
        <p>{cat.description}</p>
      </a>
    ))}
  </section>

  <section class="home-latest">
    <h2>Ultimi articoli</h2>
    <ul>
      {latestPosts.map((post) => (
        <li>
          <a href={`/articoli/${post.slug}/`}>{post.title}</a>
        </li>
      ))}
    </ul>
  </section>

  <section class="cta" style="text-align:center; margin-top:2rem;">
    <a href="/articoli/" style="font-size:1rem; font-weight:600; color:var(--primary-color);">
      Vai alla pagina Articoli&nbsp;→
    </a>
  </section>

</BaseLayout>

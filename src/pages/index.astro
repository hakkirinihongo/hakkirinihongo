---
import BaseLayout from '../layouts/BaseLayout.astro';

const categories = [
  {
    slug: 'concetti-e-distinzioni',
    title: 'Concetti\ne Distinzioni',
    description: 'Distinguere per comprendere.'
  },
  {
    slug: 'dissezionamenti-grammaticali',
    title: 'Dissezioni\nGrammaticali',
    description: 'Approfondimenti sulle regole del giapponese.'
  },
  {
    slug: 'giapponese-di-nicchia',
    title: 'Giapponese\ndi Nicchia',
    description: 'Quello che di solito non viene spiegato.'
  },
  {
    slug: 'storia-della-grammatica',
    title: 'Storia della\nGrammatica',
    description: 'Le origini della lingua.'
  }
];

const postModules = import.meta.glob('../content/articoli/**/*.mdx', { eager: true });

const posts = Object.entries(postModules).map(([path, mod]) => {
  const frontmatter = mod.frontmatter ?? {};
  const fallbackSlug = path.split('/').pop().replace('.mdx', '');
  const slug = frontmatter.slug ?? fallbackSlug;

  return {
    slug,
    title: frontmatter.title ?? slug,
    date: frontmatter.date ?? '',
    image: frontmatter.image ?? '/images/article-placeholder.jpg',
  };
});

posts.sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());

const latestPosts = posts.slice(0, 3);

const formatDate = (date) => {
  if (!date) return '';
  return new Date(date).toLocaleDateString('it-IT', {
    day: 'numeric',
    month: 'long',
    year: 'numeric',
  });
};
---

<BaseLayout title="Hakkiri Nihongo | grammatica giapponese avanzata spiegata chiaramente">

  <section class="hn-home-hero">
    <div class="hn-home-hero__overlay">
      <div class="hn-home-hero__content">
        <h1>Hakkiri Nihongo</h1>
        <p class="hn-home-hero__subtitle">Capire il giapponese oltre le regole</p>
        <p class="hn-home-hero__text">
          Il vostro punto di riferimento per la grammatica giapponese avanzata.
        </p>
        <a href="/articoli/" class="hn-home-hero__button">
          Sfoglia gli articoli
        </a>
      </div>
    </div>
  </section>

  <main class="hn-home-main">

    <section class="hn-home-categories">
      {categories.map((cat, index) => (
        <a href={`/articoli/c/${cat.slug}/`} class={`hn-home-category-card cat-${index}`}>
          <h2>{cat.title}</h2>
          <p>{cat.description}</p>
        </a>
      ))}
    </section>

    <section class="hn-home-latest">
      <h2>Ultimi Articoli</h2>

      <div class="hn-home-latest-grid">
        {latestPosts.map((post) => (
          <article class="hn-home-post-card">
            <a href={`/articoli/${post.slug}/`}>
              <img src={post.image} alt="" loading="lazy" />
              <div class="hn-home-post-card__body">
                <h3>{post.title}</h3>
                {post.date && <p>{formatDate(post.date)}</p>}
              </div>
            </a>
          </article>
        ))}
      </div>

      <div class="hn-home-all-link">
        <a href="/articoli/">Leggi tutti gli articoli&nbsp;›</a>
      </div>
    </section>

  </main>

</BaseLayout>
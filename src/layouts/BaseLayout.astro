---
// Base layout component per Hakkiri Nihongo.
// Fornisce header, footer, meta SEO e import dei CSS globali.
import '../styles/global.css';

export interface Props {
  title?: string;
  description?: string;
  image?: string;
  canonical?: string;
  noindex?: boolean;
}

const {
  title = 'Hakkiri Nihongo | grammatica giapponese avanzata spiegata chiaramente',
  description = 'Hakkiri Nihongo: grammatica giapponese avanzata, concetti, distinzioni e grammatica di nicchia spiegati chiaramente.',
  image = 'https://hakkirinihongo.com/og-image.png',
  canonical,
  noindex = false
} = Astro.props as Props;

// Canonical coerente con trailing slash finale
const canonicalURL =
  canonical ??
  new URL(Astro.url.pathname.replace(/\/?$/, '/'), Astro.site).href;
---

<!DOCTYPE html>
<html lang="it">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>

    <meta name="description" content={description} />
    <meta name="robots" content={noindex ? 'noindex, nofollow' : 'index, follow'} />

    <link rel="canonical" href={canonicalURL} />

    <!-- Structured data -->
    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        '@context': 'https://schema.org',
        '@type': 'WebSite',
        name: 'Hakkiri Nihongo',
        url: 'https://hakkirinihongo.com/',
        inLanguage: 'it',
        publisher: {
          '@type': 'Organization',
          name: 'Hakkiri Nihongo'
        }
      })}
    ></script>

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:site_name" content="Hakkiri Nihongo" />
    <meta property="og:image" content={image} />
    <meta property="og:image:alt" content="Hakkiri Nihongo | grammatica giapponese spiegata chiaramente" />
    <meta property="og:locale" content="it_IT" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image} />

    <!-- Favicons -->
    <link rel="icon" href="/favicons/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" href="/favicons/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/favicons/favicon.svg" />
    <link rel="apple-touch-icon" sizes="180x180" href="/favicons/apple-touch-icon.png" />
    <link rel="manifest" href="/favicons/site.webmanifest" />

    <meta name="theme-color" content="#ffffff" />
    <meta name="msapplication-TileColor" content="#ffffff" />
  </head>

  <body>
    <header class="site-header">
      <div class="header-inner">
        <div class="site-title">
          <a href="/" class="site-logo">
            <span class="logo-jp">はっきり日本語</span>
            <span class="logo-it">il giapponese chiaramente</span>
          </a>
        </div>

        <nav class="site-nav">
          <a href="/">Home</a>
          <a href="/articoli/">Articoli</a>
          <a href="/chi-siamo/">Chi siamo / Metodo</a>
          <a href="/contatti/">Contatti</a>
        </nav>
      </div>
    </header>

    <main class="container">
      <slot />
    </main>

    <footer class="site-footer">
  <p><strong>Hakkiri Nihongo – Il giapponese chiaramente</strong></p>

  <p>
    Sito dedicato allo studio della grammatica giapponese:
    concetti, distinzioni, grammatica di nicchia e dissezionamenti grammaticali spiegati chiaramente.
  </p>

  <!-- NUOVA RIGA -->
  <p>
    Segui Hakkiri Nihongo anche su
    <a href="https://www.facebook.com/hakkirinihongo" target="_blank" rel="noopener noreferrer">
      Facebook
    </a>
  </p>

  <p>
    © {new Date().getFullYear()} Hakkiri Nihongo. Tutti i diritti riservati.
  </p>
</footer>
<script>
  if (window.location.search.includes('fbclid')) {
    const url = new URL(window.location);
    url.searchParams.delete('fbclid');
    window.history.replaceState({}, document.title, url.pathname + url.search);
  }
</script>
  </body>
</html>
